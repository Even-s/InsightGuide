# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://insightguide:insightguide_password@localhost:5432/insightguide

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OpenAI - REQUIRED for Document Analysis
OPENAI_API_KEY=sk-...
DOCUMENT_ANALYSIS_MODEL=gpt-5.5
SEMANTIC_UNDERSTANDING_MODEL=gpt-5.4-mini  # Use gpt-5.4-mini (fastest), gpt-4o-mini, or gpt-4o for higher accuracy
EMBEDDING_MODEL=text-embedding-3-large
REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper

# Application
SECRET_KEY=your-secret-key-change-this-in-production
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:5174","http://localhost:3000"]

# S3 Storage (MinIO for local development)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=insightguide-uploads
S3_REGION=us-east-1

# File Processing
MAX_UPLOAD_SIZE=50000000
ALLOWED_EXTENSIONS=["pdf","docx","doc","md","txt"]

# Session
SESSION_TIMEOUT_SECONDS=7200
REALTIME_SESSION_TIMEOUT_SECONDS=3600
