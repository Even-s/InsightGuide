# Public mode: both DNS names must point to the EC2 Elastic IP before deployment.
APP_SITE_ADDRESS=insightguide.example.com
FILES_SITE_ADDRESS=files.insightguide.example.com
APP_ORIGIN=https://insightguide.example.com
FILES_ORIGIN=https://files.insightguide.example.com
ACME_EMAIL=admin@example.com

# Host bindings. MinIO stays loopback-only and is normally reached through Caddy.
WEB_HTTP_BIND=0.0.0.0:80
WEB_HTTPS_BIND=0.0.0.0:443
MINIO_API_BIND=127.0.0.1:9000

# Image/version label used by Docker Compose.
IMAGE_TAG=ec2
WEB_CONCURRENCY=2
CELERY_CONCURRENCY=2

# Use URL-safe values without :, /, @, # or whitespace.
POSTGRES_USER=insightguide
POSTGRES_PASSWORD=replace_with_a_long_url_safe_password
POSTGRES_DB=insightguide
REDIS_PASSWORD=replace_with_a_long_url_safe_password
SECRET_KEY=replace_with_at_least_64_random_characters

# MinIO credentials are only used inside the Docker network and for signed URLs.
MINIO_ROOT_USER=insightguide_minio
MINIO_ROOT_PASSWORD=replace_with_a_long_random_password
S3_BUCKET_NAME=insightguide-uploads
S3_REGION=us-east-1

# Required application secret.
OPENAI_API_KEY=sk-replace-me

# Optional model overrides.
DOCUMENT_ANALYSIS_MODEL=gpt-5.5
SEMANTIC_UNDERSTANDING_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=text-embedding-3-large
REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper

# Application limits.
MAX_UPLOAD_SIZE=50000000
SESSION_TIMEOUT_SECONDS=7200
REALTIME_SESSION_TIMEOUT_SECONDS=3600

# Optional off-instance backup destination, for example s3://my-backup-bucket/insightguide.
AWS_BACKUP_URI=
BACKUP_RETENTION_DAYS=7
